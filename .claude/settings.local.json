{
  "permissions": {
    "allow": [
      "Bash(npm test*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)"
    ]
  },
  "mcpServers": {
    "stock-analyzer": {
      "command": "node",
      "args": ["./mcp-server/dist/index.js"],
      "env": {
        "DATA_DIR": "./data",
        "TEMPLATE_DIR": "./templates",
        "OUTPUT_DIR": "./output"
      }
    }
  }
}
